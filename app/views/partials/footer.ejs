</div> <!-- END content-wrapper -->

<div class="footer">
    <% if (typeof themeTokens !== "undefined" && themeTokens && themeTokens.footer_tagline) { %><div class="footer-tagline" style="font-weight:600;margin-bottom:4px;color:var(--theme-footer-text);"><%= themeTokens.footer_tagline %></div><% } %>
    © <%= new Date().getFullYear() %> Attendr. Australian Owned And Operated.
</div>

<script>
document.addEventListener("DOMContentLoaded", () => {

    // Global delete confirmation (ALL delete forms)
    document.querySelectorAll("form[action*='/delete']").forEach(form => {
        form.addEventListener("submit", event => {

            const confirmed = confirm(
                "⚠️ Are you sure?\n\nThis action cannot be undone."
            );

            if (!confirmed) {
                event.preventDefault();
                event.stopPropagation();
            }
        });
    });

});
</script>

</body>
</html>
