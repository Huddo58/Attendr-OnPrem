<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Attenddr - Set Password</title>
    <link rel="icon" type="image/png" href="/img/attendr.png">

    <style>
        <%
            const brandColor = branding?.brand_color || '#0d2b4d';
        %>

        * { box-sizing: border-box; }

        body {
            margin: 0;
            min-height: 100vh;
            font-family: "Inter", Arial, sans-serif;
            /* ✅ Dynamic gradient from branding settings */
            background: linear-gradient(
                to bottom right,
                <%= branding.brand_color_light || '#6ea0c8' %>,
                <%= brandColor %>
            );
            color: #fff;
            display: flex;
            flex-direction: column;
        }

        .header {
            width: 100%;
            min-height: 95px;
            background: rgba(255,255,255,0.08);
            backdrop-filter: blur(8px);
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 20px;
            padding: 0 40px;
            border-bottom: 1px solid rgba(255,255,255,0.25);
        }

        .header-left {
            display: flex;
            align-items: center;
            gap: 14px;
            min-width: 0;
        }

        .logo img {
            width: 95px;
            user-select: none;
            filter: drop-shadow(0 2px 4px rgba(0,0,0,0.25));
        }

        .org-name {
            font-size: 18px;
            font-weight: 700;
            letter-spacing: 0.2px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            max-width: 420px;
        }

        .header-meta {
            font-size: 13px;
            opacity: 0.9;
            white-space: nowrap;
        }

        .reset-shell {
            flex: 1;
            width: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 42px 20px;
        }

        .reset-card {
            width: 430px;
            max-width: 100%;
            background: rgba(255,255,255,0.16);
            border: 1px solid rgba(255,255,255,0.28);
            border-radius: 12px;
            backdrop-filter: blur(10px);
            box-shadow: 0 12px 30px rgba(0,0,0,0.25);
            padding: 36px 40px 34px;
        }

        .reset-card h1 {
            margin: 0 0 8px;
            font-size: 24px;
            font-weight: 650;
            color: #fff;
        }

        .reset-card p {
            margin: 0 0 24px;
            color: rgba(255,255,255,0.82);
            font-size: 14px;
            line-height: 1.45;
        }

        label {
            display: block;
            margin-top: 14px;
            margin-bottom: 5px;
            font-size: 14px;
            color: #e6e6e6;
            font-weight: 600;
        }

        input {
            width: 100%;
            padding: 12px;
            border-radius: 6px;
            border: none;
            font-size: 15px;
            outline: none;
            background: #fff;
            color: #1a1a1a;
        }

        input:focus {
            box-shadow: 0 0 0 3px rgba(255,255,255,0.24);
        }

        /* ✅ PASSWORD REQUIREMENTS LIST */
        .password-rules {
            margin: 10px 0 0;
            padding: 0;
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 5px;
        }

        .password-rules li {
            font-size: 12px;
            color: rgba(255,255,255,0.6);
            display: flex;
            align-items: center;
            gap: 7px;
            transition: color 0.2s;
        }

        .password-rules li.met {
            color: #6ee7b7;
        }

        .rule-icon {
            width: 14px;
            height: 14px;
            border-radius: 50%;
            border: 1.5px solid rgba(255,255,255,0.3);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            font-size: 9px;
            transition: all 0.2s;
        }

        .met .rule-icon {
            background: #10b981;
            border-color: #10b981;
            color: white;
        }

        /* MATCH INDICATOR */
        .match-indicator {
            font-size: 12px;
            margin-top: 6px;
            min-height: 16px;
            transition: color 0.2s;
        }

        .match-ok   { color: #6ee7b7; }
        .match-fail { color: #fca5a5; }

        .btn-primary {
            width: 100%;
            margin-top: 22px;
            padding: 12px;
            background: rgba(0,0,0,0.3);
            border: 1px solid rgba(255,255,255,0.2);
            color: white;
            border-radius: 6px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: 0.2s;
        }

        .btn-primary:hover   { background: rgba(0,0,0,0.45); }
        .btn-primary:disabled {
            opacity: 0.45;
            cursor: not-allowed;
        }

        .error {
            margin-top: 16px;
            padding: 10px 12px;
            border-radius: 6px;
            background: rgba(255,179,179,0.16);
            border: 1px solid rgba(255,179,179,0.45);
            color: #ffd6d6;
            font-size: 13px;
        }

        .footer {
            width: 100%;
            text-align: center;
            color: white;
            opacity: 0.75;
            font-size: 12px;
            padding: 0 0 22px;
        }

        @media (max-width: 640px) {
            .header {
                padding: 18px 22px;
                align-items: flex-start;
                flex-direction: column;
            }
            .logo img { width: 82px; }
            .org-name { max-width: 260px; }
            .reset-card { padding: 30px 24px 28px; }
        }
    </style>
</head>

<body>
    <div class="header">
        <div class="header-left">
            <div class="logo">
                <%
                    /* ✅ Use custom logo if set, otherwise Attenddr default */
                    const resetLogo = (branding && branding.logo_path)
                        ? branding.logo_path
                        : '/img/attendr.png';
                %>
                <img src="<%= resetLogo %>" alt="Logo">
            </div>
            <div class="org-name">
                <%= (settings && settings.org_name) ? settings.org_name : "Attenddr" %>
            </div>
        </div>

        <div class="header-meta">
            Logged in as <strong><%= user && user.name ? user.name : "User" %></strong>
        </div>
    </div>

    <main class="reset-shell">
        <section class="reset-card">
            <h1>Set a new password</h1>
            <p>Your administrator has issued a temporary password. Choose a new password before continuing.</p>

            <form method="POST" action="/reset-password" id="resetForm">

                <label for="password">New password</label>
                <input
                    id="password"
                    type="password"
                    name="password"
                    autocomplete="new-password"
                    required
                    oninput="checkRules()"
                >

                <!-- ✅ PASSWORD RULES -->
                <ul class="password-rules" id="passwordRules">
                    <li id="rule-length">
                        <span class="rule-icon">✓</span>
                        At least 8 characters
                    </li>
                    <li id="rule-upper">
                        <span class="rule-icon">✓</span>
                        At least one uppercase letter (A–Z)
                    </li>
                    <li id="rule-lower">
                        <span class="rule-icon">✓</span>
                        At least one lowercase letter (a–z)
                    </li>
                    <li id="rule-number">
                        <span class="rule-icon">✓</span>
                        At least one number (0–9)
                    </li>
                    <li id="rule-special">
                        <span class="rule-icon">✓</span>
                        At least one special character (!@#$%^&*)
                    </li>
                </ul>

                <label for="confirm_password">Confirm password</label>
                <input
                    id="confirm_password"
                    type="password"
                    name="confirm_password"
                    autocomplete="new-password"
                    required
                    oninput="checkMatch()"
                >

                <div class="match-indicator" id="matchIndicator"></div>

                <button class="btn-primary" type="submit" id="submitBtn" disabled>
                    Update Password
                </button>
            </form>

            <% if (typeof error !== "undefined" && error) { %>
                <div class="error"><%= error %></div>
            <% } %>
        </section>
    </main>

    <div class="footer">
        &copy; <%= new Date().getFullYear() %> Attenddr. Australian Owned And Operated.
    </div>

    <script>
    const rules = {
    length:  { el: document.getElementById('rule-length'),  test: v => v.length >= 8 },
    upper:   { el: document.getElementById('rule-upper'),   test: v => /[A-Z]/.test(v) },
    lower:   { el: document.getElementById('rule-lower'),   test: v => /[a-z]/.test(v) },
    number:  { el: document.getElementById('rule-number'),  test: v => /[0-9]/.test(v) },
    special: { el: document.getElementById('rule-special'), test: v => /[!@#$%^&*()_+\-=\[\]{};':"\\|,.<>\/?]/.test(v) }
};

function evalRules() {
    const val = document.getElementById('password').value;
    let allMet = true;
    for (const key in rules) {
        const met = rules[key].test(val);
        rules[key].el.classList.toggle('met', met);
        if (!met) allMet = false;
    }
    return allMet;
}

function checkRules() {
    evalRules();
    updateButton();
}

function checkMatch() {
    updateButton();
}

function updateButton() {
    const pass      = document.getElementById('password').value;
    const confirm   = document.getElementById('confirm_password').value;
    const indicator = document.getElementById('matchIndicator');
    const btn       = document.getElementById('submitBtn');
    const allRules  = evalRules();

    if (!confirm) {
        indicator.textContent = '';
        btn.disabled = true;
        return;
    }

    if (pass === confirm && allRules) {
        indicator.textContent = 'Passwords match';
        indicator.className   = 'match-indicator match-ok';
        btn.disabled = false;
    } else if (pass !== confirm) {
        indicator.textContent = 'Passwords do not match';
        indicator.className   = 'match-indicator match-fail';
        btn.disabled = true;
    } else {
        indicator.textContent = '';
        btn.disabled = true;
    }
}

document.getElementById('resetForm').addEventListener('submit', function(e) {
    const allRules = evalRules();
    const pass    = document.getElementById('password').value;
    const confirm = document.getElementById('confirm_password').value;
    if (!allRules || pass !== confirm) {
        e.preventDefault();
        return false;
    }
});
    </script>

</body>
</html>
