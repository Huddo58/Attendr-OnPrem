<%- include("../partials/header", {
    pageTitle: "Attendr - Departments",
    activeTab: "departments",
    query: query,
    pageStyles: `

        /* TABLE */
        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 14px;
        }
        th, td {
            padding: 10px 12px;
            border-bottom: 1px solid #ddd;
            text-align: left;
        }
        th {
            font-size: 13px;
            color: #444;
            background: #f4f7fb;
        }

        /* ACTION BUTTONS */
        .actions {
            text-align: right;
            padding-right: 20px;
        }

        .delete-btn, .edit-btn {
            background: none;
            border: none;
            cursor: pointer;
            padding: 4px;
            transition: 0.2s;
        }
        .delete-btn:hover, .edit-btn:hover {
            transform: scale(1.12);
            opacity: 0.85;
        }

        .icon-trash, .icon-edit {
            width: 20px;
            height: 20px;
            pointer-events: none;
        }

        .icon-trash { color: #d11a2a; }
        .icon-edit { color: var(--primary-color); }
/* POPUP */
.popup-overlay {
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    background: rgba(0,0,0,0.45);
    backdrop-filter: blur(4px);
    display: none;
    justify-content: center;
    align-items: center;
    z-index: 2000;
}

.popup-box {
    width: 420px;
    background: white;
    border-radius: 12px;
    box-shadow: 0 0 25px rgba(0,0,0,0.25);
    overflow: hidden;
}

.popup-header {
    padding: 18px 22px;
    background: var(--primary-color);
    color: white;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.popup-close {
    background: none;
    border: none;
    color: white;
    font-size: 18px;
    cursor: pointer;
}

/* FIXED SPACING */
.popup-content {
    padding: 24px 26px;     /* wider padding fixes inputs touching right edge */
    box-sizing: border-box; /* ensures inputs respect padding */
}

/* FIXED INPUT BOXES */
.popup-content input {
    width: 100%;
    box-sizing: border-box; /* ensures padding stays inside element width */
    padding: 12px 14px;
    border-radius: 6px;
    border: 1px solid #ccc;
    margin-bottom: 18px;
    font-size: 14px;
    background: #fff;
}

.popup-content label {
    font-weight: 600;
    display: block;
    margin-bottom: 6px;
    font-size: 14px;
}

.popup-actions {
    padding: 15px 25px;
    background: #f5f5f5;
    text-align: right;
}

.popup-btn {
    padding: 8px 16px;
    border-radius: 6px;
    border: none;
    cursor: pointer;
    margin-left: 8px;
    font-size: 14px;
}

.popup-btn.cancel { background: #ddd; }
.popup-btn.save { background: var(--primary-color); color: white; }

    `
}) %>

<div class="section-title">Departments</div>
<div class="section-subtitle">Add, rename, or remove departments.</div>

<div class="toolbar">
    <button class="btn-primary" onclick="openAddDept()">+ Add Department</button>
</div>

<table>
    <thead>
        <tr>
            <th>Department Name</th>
            <th>Code</th>
            <th>Description</th>
            <th></th>
        </tr>
    </thead>

    <tbody>
        <% departments.forEach(department => { %>
            <tr>
                <td><%= department.name %></td>
                <td><%= department.code %></td>
                <td><%= department.description %></td>

                <td class="actions">
                    <button
                        class="edit-btn"
                        title="Edit"
                    >
                        <svg class="icon-edit" viewBox="0 0 24 24">
                            <path d="M4 21v-4l12-12 4 4-12 12H4z"
                                  stroke="currentColor" stroke-width="2"
                                  stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                        </svg>
                    </button>

                    <form action="/admin/departments/delete/<%= department.id %>" method="POST" style="display:inline;">
                        <button class="delete-btn" title="Delete">
                            <svg class="icon-trash" viewBox="0 0 24 24">
                                <path d="M3 6h18M9 6V4h6v2m-7 4v10m4-10v10m4-10v10M5 6l1 14h12l1-14"
                                      stroke="currentColor" stroke-width="2" fill="none"
                                      stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </button>
                    </form>
                </td>
            </tr>
        <% }) %>
    </tbody>
</table>

<!-- ADD DEPARTMENT POPUP -->
<div id="addDeptPopup" class="popup-overlay">
    <div class="popup-box">

        <div class="popup-header">
            <div>Add Department</div>
            <button class="popup-close" onclick="closeAddDept()">&times;</button>
        </div>

        <form action="/admin/departments/create" method="POST">
            <div class="popup-content">
                <label>Department Name</label>
                <input name="name" placeholder="" required>

                <label>Department Code</label>
                <input name="code" placeholder="" required>

                <label>Description</label>
                <input name="description" placeholder="">
            </div>

            <div class="popup-actions">
                <button type="button" class="popup-btn cancel" onclick="closeAddDept()">Cancel</button>
                <button class="popup-btn save" type="submit">Save</button>
            </div>
        </form>

    </div>
</div>

<!-- EDIT DEPARTMENT POPUP -->
<div id="editDeptPopup" class="popup-overlay">
    <div class="popup-box">

        <div class="popup-header">
            <div>Edit Department</div>
            <button class="popup-close" onclick="closeEditDept()">&times;</button>
        </div>

        <form id="editDeptForm" method="POST">
            <div class="popup-content">
                <label>Department Name</label>
                <input name="name" id="editDeptName" required>

                <label>Department Code</label>
                <input name="code" id="editDeptCode" required>

                <label>Description</label>
                <input name="description" id="editDeptDescription">
            </div>

            <div class="popup-actions">
                <button type="button" class="popup-btn cancel" onclick="closeEditDept()">Cancel</button>
                <button class="popup-btn save" type="submit">Save Changes</button>
            </div>
        </form>

    </div>
</div>

<script>
function openAddDept() {
    document.getElementById("addDeptPopup").style.display = "flex";
}
function closeAddDept() {
    document.getElementById("addDeptPopup").style.display = "none";
}
function openEditDept(button) {
    const row = button.closest("tr");
    const deleteForm = row.querySelector("form[action*='/departments/delete/']");
    const departmentId = deleteForm.action.split("/").pop();

    document.getElementById("editDeptName").value = row.cells[0].innerText.trim();
    document.getElementById("editDeptCode").value = row.cells[1].innerText.trim();
    document.getElementById("editDeptDescription").value = row.cells[2].innerText.trim();
    document.getElementById("editDeptForm").action = "/admin/departments/edit/" + departmentId;
    document.getElementById("editDeptPopup").style.display = "flex";
}
function closeEditDept() {
    document.getElementById("editDeptPopup").style.display = "none";
}

document.querySelectorAll(".edit-btn").forEach(button => {
    button.addEventListener("click", () => openEditDept(button));
});
</script>

<%- include("../partials/footer") %>
