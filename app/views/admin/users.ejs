<%- include("../partials/header", {
    pageTitle: "Attenddr – Users",
    activeTab: "users",
    query: query,
    pageStyles: `
        table { width:100%; border-collapse:collapse; font-size:14px; }
        th, td { padding:12px 14px; border-bottom:1px solid #ddd; }
        th { background:#f4f7fb; color:#444; text-align:left; }

        .actions {
            display:flex;
            justify-content:flex-end;
            align-items:center;
            gap:30px;
            padding-right:30px;
            white-space:nowrap;
        }

        .edit-btn, .delete-btn {
            background:none;
            border:none;
            cursor:pointer;
            padding:4px;
            opacity:0.9;
            transition:0.2s;
        }
        .edit-btn:hover,
        .delete-btn:hover { opacity:1; transform:scale(1.12); }

        .icon-edit { width:20px; height:20px; color:var(--primary-color); }
        .icon-trash { width:20px; height:20px; color:#d11a2a; }

        .reset-btn {
            background:#c62828;
            color:white;
            border:none;
            padding:6px 15px;
            border-radius:6px;
            font-size:13px;
            cursor:pointer;
        }
        .reset-btn:hover { background:#a51f1f; }

        /* POPUPS */
        .popup-overlay {
            position:fixed;
            inset:0;
            background:rgba(0,0,0,0.45);
            backdrop-filter:blur(4px);
            display:none;
            justify-content:center;
            align-items:center;
            z-index:2000;
        }

        .popup-box {
            width:560px;
            background:white;
            border-radius:12px;
            box-shadow:0 0 25px rgba(0,0,0,0.25);
            overflow:hidden;
            max-height:90vh;
            overflow-y:auto;
        }

        .popup-header {
            background:var(--primary-color);
            color:white;
            padding:18px 22px;
            display:flex;
            justify-content:space-between;
            align-items:center;
            position:sticky;
            top:0;
            z-index:10;
        }

        .popup-close {
            background:none;
            border:none;
            color:white;
            font-size:18px;
            cursor:pointer;
        }

        .popup-content { padding:25px 30px; }

        .popup-content label {
            font-weight:600;
            margin-bottom:6px;
            display:block;
        }

        .popup-content input,
        .popup-content select {
            width:100%;
            padding:12px 14px;
            border-radius:6px;
            border:1px solid #ccc;
            margin-bottom:18px;
            box-sizing:border-box;
            font-size:14px;
        }

        .popup-section-title {
            font-size:12px;
            font-weight:700;
            color:#555;
            text-transform:uppercase;
            letter-spacing:0.4px;
            margin-bottom:12px;
            padding-top:4px;
            border-top:1px solid #eee;
        }

        .popup-hint {
            font-size:12px;
            color:#777;
            margin-top:-12px;
            margin-bottom:16px;
            line-height:1.5;
        }

        .dept-grid {
            display:flex;
            flex-direction:column;
            gap:10px;
            margin-bottom:18px;
        }

        .dept-item {
            display:flex;
            align-items:center;
            gap:12px;
            font-size:15px;
            cursor:pointer;
        }

        .dept-item input[type="checkbox"] {
            margin:0;
            transform: translateY(20px);
        }

        .dept-item span { font-weight:500; }

        .popup-actions {
            padding:15px 25px;
            background:#f5f5f5;
            text-align:right;
            position:sticky;
            bottom:0;
        }

        .popup-btn {
            padding:8px 16px;
            border:none;
            border-radius:6px;
            cursor:pointer;
            margin-left:8px;
            font-size:14px;
        }

        .popup-btn.cancel { background:#ddd; }
        .popup-btn.save { background:var(--primary-color); color:white; }
    `
}) %>

<%
    const currentCount = users ? users.length : 0;
    let maxUsers;

    if (!license || !license.valid) {
        maxUsers = "Licence Expired";
    } else if (license.max_users === -1) {
        maxUsers = "Unlimited";
    } else {
        maxUsers = license.max_users;
    }
%>

<div class="section-title">
    Users (<%= currentCount %> / <%= maxUsers %>)
</div>
<div class="section-subtitle">
    Manage accounts, roles, department access, and status preferences.
</div>

<!-- LICENSE LIMIT POPUP -->
<% if (query && query.error === "user_limit") { %>
<div class="popup-overlay" style="display:flex;">
    <div class="popup-box">
        <div class="popup-header">
            <div>License Limit Reached</div>
            <button class="popup-close"
                onclick="this.closest('.popup-overlay').remove()">✖</button>
        </div>
        <div class="popup-content">
            <p><strong>You have reached the maximum number of users allowed.</strong></p>
            <p style="margin-top:10px;">
                Your current license does not permit adding more users.
                Please upgrade your license to continue.
            </p>
        </div>
        <div class="popup-actions">
            <button class="popup-btn save"
                onclick="this.closest('.popup-overlay').remove(); history.replaceState({}, document.title, window.location.pathname);">
                OK
            </button>
        </div>
    </div>
</div>
<% } %>

<!-- PASSWORD RESET SUCCESS POPUP -->
<% if (query && query.passwordReset) { %>
<div class="popup-overlay" style="display:flex;">
    <div class="popup-box">
        <div class="popup-header">
            <div>Password Reset</div>
            <button class="popup-close"
                onclick="this.closest('.popup-overlay').remove()">✖</button>
        </div>
        <div class="popup-content">
            <p><strong>Password reset successful.</strong></p>
            <p style="margin-top:10px;">The temporary password has been reset to:</p>
            <code style="display:inline-block;margin-top:8px;padding:8px 12px;background:#f4f4f4;border-radius:6px;font-size:16px;">
                Attendr123!
            </code>
            <p style="margin-top:14px; font-size:14px;">
                The user will be required to change this password on their next login.
            </p>
        </div>
        <div class="popup-actions">
            <button class="popup-btn save"
                onclick="this.closest('.popup-overlay').remove()">OK</button>
        </div>
    </div>
</div>
<% } %>

<div class="toolbar">
    <button class="btn-primary" onclick="openAddUser()">+ Add User</button>
</div>

<table>
    <thead>
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Role</th>
            <th>Departments</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    <% users.forEach(u => { %>
    <tr>
        <td><a href="/profile?userId=<%= u.id %>"><%= u.name %></a></td>
        <td><%= u.email %></td>
        <td><%= u.role %></td>
        <td><%= u.departments || "—" %></td>
        <td class="actions">

            <button class="edit-btn" title="Edit User"
                onclick="openEditUser(<%= u.id %>, '<%= u.name %>', '<%= u.email %>', '<%= u.role %>', `<%= u.departments || '' %>`)">
                <svg class="icon-edit" viewBox="0 0 24 24">
                    <path d="M4 21v-4l12-12 4 4-12 12H4z"
                          stroke="currentColor" stroke-width="2"
                          stroke-linecap="round" stroke-linejoin="round"
                          fill="none"/>
                </svg>
            </button>

            <form action="/admin/users/reset/<%= u.id %>" method="POST" style="display:inline;">
                <button class="reset-btn">Reset Password</button>
            </form>

            <form action="/admin/users/delete/<%= u.id %>" method="POST" style="display:inline;">
                <button class="delete-btn" title="Delete User">
                    <svg class="icon-trash" viewBox="0 0 24 24">
                        <path d="M3 6h18M9 6V4h6v2m-7 4v10m4-10v10m4-10v10M5 6l1 14h12l1-14"
                              stroke="currentColor" stroke-width="2"
                              stroke-linecap="round" stroke-linejoin="round"
                              fill="none"/>
                    </svg>
                </button>
            </form>

        </td>
    </tr>
    <% }) %>
    </tbody>
</table>

<!-- ADD USER POPUP -->
<div id="addUserPopup" class="popup-overlay">
    <div class="popup-box">
        <div class="popup-header">
            <div>Add User</div>
            <button class="popup-close" onclick="closeAddUser()">✖</button>
        </div>

        <form action="/admin/users/create" method="POST">
            <div class="popup-content">

                <label>Name</label>
                <input name="name" required>

                <label>Email</label>
                <input name="email" required>

                <label>Password</label>
                <input type="password" name="password" required>

                <label>Role</label>
                <select name="role">
                    <option value="user">User</option>
                    <option value="admin">Admin</option>
                </select>

                <label>Departments</label>
                <div class="dept-grid">
                    <% departments.forEach(d => { %>
                    <label class="dept-item">
                        <input type="checkbox" name="departments" value="<%= d.id %>">
                        <span><%= d.name %></span>
                    </label>
                    <% }) %>
                </div>

                <!-- ✅ NEW: STATUS PREFERENCES -->
                <div class="popup-section-title" style="margin-top:8px;">Status Preferences</div>
                <div class="popup-hint">
                    These settings automate the user's status when Attenddr detects their
                    location by IP address. Can be changed later from their profile.
                </div>

                <label>Default Location</label>
                <select name="default_location_id">
                    <option value="">— Not set —</option>
                    <% if (typeof locations !== 'undefined') { %>
                        <% locations.forEach(loc => { %>
                            <option value="<%= loc.id %>"><%= loc.name %></option>
                        <% }) %>
                    <% } %>
                </select>

                <label>Home Status <span style="font-weight:400;color:#888;font-size:12px;">(when at default location)</span></label>
                <select name="home_status_id">
                    <option value="">— Not set —</option>
                    <% if (typeof statuses !== 'undefined') { %>
                        <% statuses.forEach(s => { %>
                            <option value="<%= s.id %>"><%= s.name %></option>
                        <% }) %>
                    <% } %>
                </select>

                <label>Away Status <span style="font-weight:400;color:#888;font-size:12px;">(when at another detected location)</span></label>
                <select name="away_status_id">
                    <option value="">— Not set —</option>
                    <% if (typeof statuses !== 'undefined') { %>
                        <% statuses.forEach(s => { %>
                            <option value="<%= s.id %>"><%= s.name %></option>
                        <% }) %>
                    <% } %>
                </select>

            </div>

            <div class="popup-actions">
                <button type="button" class="popup-btn cancel" onclick="closeAddUser()">Cancel</button>
                <button class="popup-btn save">Save</button>
            </div>
        </form>
    </div>
</div>

<!-- EDIT USER POPUP -->
<div id="editUserPopup" class="popup-overlay">
    <div class="popup-box">
        <div class="popup-header">
            <div>Edit User</div>
            <button class="popup-close" onclick="closeEditUser()">✖</button>
        </div>

        <form id="editUserForm" method="POST">
            <div class="popup-content">
                <label>Name</label>
                <input id="editName" name="name" required>

                <label>Email</label>
                <input id="editEmail" name="email" required>

                <label>Role</label>
                <select id="editRole" name="role">
                    <option value="user">User</option>
                    <option value="admin">Admin</option>
                </select>

                <label>Departments</label>
                <div id="editDeptGrid" class="dept-grid">
                    <% departments.forEach(d => { %>
                    <label class="dept-item">
                        <input type="checkbox" name="departments" value="<%= d.id %>">
                        <span><%= d.name %></span>
                    </label>
                    <% }) %>
                </div>
            </div>

            <div class="popup-actions">
                <button type="button" class="popup-btn cancel" onclick="closeEditUser()">Cancel</button>
                <button class="popup-btn save">Save</button>
            </div>
        </form>
    </div>
</div>

<script>
function openAddUser() {
    document.getElementById("addUserPopup").style.display = "flex";
}
function closeAddUser() {
    document.getElementById("addUserPopup").style.display = "none";
}
function openEditUser(id, name, email, role) {
    document.getElementById("editName").value  = name;
    document.getElementById("editEmail").value = email;
    document.getElementById("editRole").value  = role;
    document.getElementById("editUserForm").action = "/admin/users/edit/" + id;
    document.getElementById("editUserPopup").style.display = "flex";
}
function closeEditUser() {
    document.getElementById("editUserPopup").style.display = "none";
}
</script>

<%- include("../partials/footer") %>
