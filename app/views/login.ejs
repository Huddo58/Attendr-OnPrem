<!DOCTYPE html>
<html lang="en">
<link rel="icon" type="image/png" href="/img/attendr.png">

<head>
    <meta charset="UTF-8" />
    <title>Attenddr - Login</title>
    <style>
        <%
            const brandColor = branding?.brand_color || '#0d2b4d';
        %>

        body {
            margin: 0;
            font-family: "Inter", Arial, sans-serif;
            /* ✅ Dynamic gradient from branding settings */
            background: linear-gradient(
                to bottom right,
                <%= branding.brand_color_light || '#6ea0c8' %>,
                <%= brandColor %>
            );
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .login-card {
            width: 420px;
            padding: 40px;
            background: rgba(255, 255, 255, 0.15);
            border-radius: 12px;
            backdrop-filter: blur(10px);
            box-shadow: 0px 5px 15px rgba(0,0,0,0.25);
            text-align: center;
        }

        .login-card img.logo {
            width: 90px;
            margin-bottom: 10px;
        }

        .login-card h2 {
            margin-bottom: 25px;
            color: #fff;
            font-weight: 500;
        }

        label {
            display: block;
            text-align: left;
            margin-top: 14px;
            margin-bottom: 4px;
            font-size: 14px;
            color: #e6e6e6;
        }

        input {
            width: 100%;
            padding: 12px;
            border-radius: 6px;
            border: none;
            font-size: 15px;
            outline: none;
            box-sizing: border-box;
        }

        .btn-login {
            width: 100%;
            padding: 12px;
            margin-top: 20px;
            background: rgba(0,0,0,0.3);
            color: white;
            border: 1px solid rgba(255,255,255,0.2);
            border-radius: 6px;
            font-size: 16px;
            cursor: pointer;
            transition: 0.2s;
        }

        .btn-login:hover {
            background: rgba(0,0,0,0.45);
        }

        .footer-text {
            margin-top: 18px;
            font-size: 12px;
            color: #d0d0d0;
        }

        /* Azure AD login button */
        .btn-azure {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            width: 100%;
            padding: 12px;
            margin-top: 12px;
            background: #0078d4;
            color: white;
            border: none;
            border-radius: 6px;
            font-size: 15px;
            font-family: inherit;
            cursor: pointer;
            text-decoration: none;
            transition: 0.2s;
        }

        .btn-azure:hover { background: #006cbf; }

        .divider {
            display: flex;
            align-items: center;
            gap: 10px;
            margin: 16px 0 4px;
            color: rgba(255,255,255,0.5);
            font-size: 12px;
        }

        .divider::before,
        .divider::after {
            content: '';
            flex: 1;
            border-top: 1px solid rgba(255,255,255,0.25);
        }
    </style>
</head>

<body>
    <div class="login-card">

        <%
            /* ✅ Use custom logo if set, otherwise Attenddr default */
            const loginLogo = (branding && branding.logo_path)
                ? branding.logo_path
                : '/img/attendr.png';
        %>
        <img src="<%= loginLogo %>" alt="Logo" class="logo" />

        <h2>Login</h2>

        <% if (typeof error !== "undefined") { %>
            <p style="color:#ffb3b3; margin-bottom:15px;"><%= error %></p>
        <% } %>

        <form action="/login" method="POST">
            <label>Email</label>
            <input type="email" name="email" required autocomplete="email" />

            <label>Password</label>
            <input type="password" name="password" required autocomplete="current-password" />

            <button class="btn-login" type="submit">Log In</button>
        </form>

        <%
            /* Show Azure AD login button if enabled */
            const azureEnabled = settings && settings.ad_azure_enabled === '1';
        %>
        <% if (azureEnabled) { %>
            <div class="divider">or</div>
            <a href="/auth/azure" class="btn-azure">
                <svg width="16" height="16" viewBox="0 0 23 23" fill="none">
                    <path d="M0 0h11v11H0z" fill="#f25022"/>
                    <path d="M12 0h11v11H12z" fill="#7fba00"/>
                    <path d="M0 12h11v11H0z" fill="#00a4ef"/>
                    <path d="M12 12h11v11H12z" fill="#ffb900"/>
                </svg>
                Sign in with Microsoft
            </a>
        <% } %>

        <div class="footer-text">
            © <%= new Date().getFullYear() %> Attenddr. Australian Owned And Operated.
        </div>
    </div>
</body>
</html>
