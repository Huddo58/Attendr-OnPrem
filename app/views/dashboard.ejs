<!DOCTYPE html>
<html lang="en">
    <link rel="icon" type="image/png" href="/img/attendr.png">

<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Attendr Dashboard</title>

<style>
<% const tk = themeTokens; %>
:root {
    --theme-bg-start:            <%= tk.bg_start %>;
    --theme-bg-end:              <%= tk.bg_end %>;
    --theme-bg-image:            <%= tk.bg_image %>;
    --theme-bg-overlay:          <%= tk.bg_overlay %>;
    --theme-header-bg:           <%= tk.header_bg %>;
    --theme-header-border:       <%= tk.header_border %>;
    --theme-header-text:         <%= tk.header_text %>;
    --theme-header-banner:       <%= tk.header_banner %>;
    --theme-header-banner-blend: <%= tk.header_banner_blend %>;
    --theme-tabs-bg:             <%= tk.tabs_bg %>;
    --theme-tabs-border:         <%= tk.tabs_border %>;
    --theme-card-bg:             <%= tk.card_bg %>;
    --theme-text-on-chrome:      <%= tk.text_on_chrome %>;
    --theme-text-heading:        <%= tk.text_heading %>;
    --theme-accent:              <%= tk.accent %>;
    --theme-accent-text:         <%= tk.accent_text %>;
    --theme-popup-header-bg:     <%= tk.popup_header_bg %>;
    --theme-popup-header-text:   <%= tk.popup_header_text %>;
    --theme-footer-text:         <%= tk.footer_text %>;
}

body {
        margin: 0;
        padding: 0;
        font-family: "Inter", Arial, sans-serif;
        background-image:
            linear-gradient(var(--theme-bg-overlay), var(--theme-bg-overlay)),
            var(--theme-bg-image),
            linear-gradient(to bottom right, var(--theme-bg-start), var(--theme-bg-end));
        background-size: cover;
        background-position: center;
        background-attachment: fixed;
        min-height: 100vh;
        color: #1a1a1a;
    }

    /* HEADER BAR */
    .header {
        width: 100%;
        height: 95px;
        background-color: var(--theme-header-bg);
        background-image: var(--theme-header-banner);
        background-blend-mode: var(--theme-header-banner-blend);
        background-size: cover;
        background-position: center;
        backdrop-filter: blur(8px);
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 40px;
        box-sizing: border-box;
        border-bottom: 1px solid var(--theme-header-border);
    }

    .header-left {
        display: flex;
        align-items: center;
        gap: 14px;
        min-width: 0;
    }

    .logo img {
        width: 95px;
        user-select: none;
        filter: drop-shadow(0 2px 4px rgba(0,0,0,0.25));
    }

    .org-name {
        color: var(--theme-header-text);
        font-size: 18px;
        font-weight: 700;
        letter-spacing: 0.2px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 420px;
    }

    .header-right {
        display: flex;
        align-items: center;
        gap: 16px;
        min-width: 0;
    }

    .admin-btn {
        padding: 7px 14px;
        border-radius: 20px;
        border: none;
        background: var(--theme-accent);
        color: var(--theme-accent-text);
        font-size: 13px;
        font-weight: 600;
        text-decoration: none;
        white-space: nowrap;
    }

    .admin-btn:hover {
        filter: brightness(1.08);
    }

    /* Search box */
    .search-box {
        display:flex;
        align-items:center;
        background:white;
        padding:8px 13px;
        border-radius:25px;
        width:260px;
    }
    .search-box input {
        border:none;
        outline:none;
        width:100%;
        font-size:14px;
    }

    .user-meta {
        color: var(--theme-header-text);
        font-size: 13px;
        white-space: nowrap;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .user-meta a {
        color: var(--theme-header-text);
        text-decoration: none;
        font-weight: 500;
    }

    .user-meta a:hover {
        text-decoration: underline;
    }

    /* ✅ NEW: Header avatar */
    .header-avatar {
        width: 34px;
        height: 34px;
        border-radius: 50%;
        object-fit: cover;
        border: 2px solid rgba(255,255,255,0.6);
        flex-shrink: 0;
    }

    .header-avatar-initials {
        width: 34px;
        height: 34px;
        border-radius: 50%;
        background: rgba(255,255,255,0.25);
        color: white;
        font-size: 12px;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 2px solid rgba(255,255,255,0.6);
        flex-shrink: 0;
        letter-spacing: 0.5px;
        text-decoration: none;
    }

    /* TABS SECTION */
    .tabs {
        width: 100%;
        display: flex;
        gap: 25px;
        padding: 15px 40px;
        background: var(--theme-tabs-bg);
        backdrop-filter: blur(6px);
        font-weight: 600;
        color: var(--theme-text-on-chrome);
        border-bottom: 1px solid var(--theme-tabs-border);
        box-sizing: border-box;
    }

    .tab {
        cursor: pointer;
        padding-bottom: 6px;
        transition: 0.2s;
        border-bottom: 2px solid transparent;
        font-size: 14px;
    }

    .tab.active {
        border-bottom: 2px solid var(--theme-accent);
    }

    /* TABLE WRAPPER */
        .panel-deco { position: absolute; pointer-events: none; user-select: none; z-index: 5; }
    .panel-deco--bl { bottom: -40px; left: -26px; width: 140px; }

    .table-wrapper {
        position: relative;
        width: 85%;
        margin: 30px auto;
        background: rgba(255,255,255,0.90);
        border-radius: 12px;
        padding: 20px 0;
        box-shadow: 0 0 25px rgba(0,0,0,0.18);
        backdrop-filter: blur(4px);
        box-sizing: border-box;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        font-size: 14px;
    }

    th {
        text-align: left;
        padding: 14px 25px;
        font-weight: 700;
        color: var(--theme-text-heading);
        border-bottom: 1px solid #ccc;
    }

    td {
        padding: 15px 25px;
        border-bottom: 1px solid #ddd;
        color: #1d1d1d;
        vertical-align: middle;
    }

    tr.user-row {
        cursor: pointer;
        transition: background 0.12s;
    }

    tr.user-row:hover {
        background: #f5f7fb;
    }

    .last-updated-date { font-weight: 500; }
    .last-updated-by { font-size: 13px; font-weight: 500; color: #555; margin-top: 2px; }

    /* ✅ NEW: Avatar circles in table */
    .user-avatar {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        object-fit: cover;
        border: 2px solid #e0e0e0;
        flex-shrink: 0;
    }

    .user-avatar-initials {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: var(--theme-accent);
        color: var(--theme-accent-text);
        font-size: 13px;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        letter-spacing: 0.5px;
    }

    .user-name-cell {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .user-name-link {
        color: inherit;
        text-decoration: none;
    }

    .user-name-link:hover {
        text-decoration: underline;
        color: var(--theme-text-heading);
    }

    /* STATUS BADGES */
    .badge {
        padding: 6px 14px;
        border-radius: 8px;
        font-weight: 600;
        color: white;
        font-size: 13px;
        display: inline-block;
        box-shadow: 0 1px 4px rgba(0,0,0,0.25);
    }

    .black { background:#000; }
    .darkgrey { background:#333; }
    .grey { background:#777; }
    .lightgrey { background:#ccc; color:#000; }
    .white { background:#fff; color:#000; }

    .navy { background:#001f3f; }
    .blue { background:#005DFF; }
    .sky { background:#66B2FF; }
    .cyan { background:#00bcd4; }
    .teal { background:#009688; }

    .darkgreen { background:#014421; }
    .green { background:#2ecc71; }
    .lightgreen { background:#7bed9f; color:#000; }
    .mint { background:#98ffcc; color:#000; }
    .lime { background:#c6ff00; color:#000; }

    .maroon { background:#800000; }
    .red { background:#ff2f2f; }
    .orange { background:#ff851b; }
    .amber { background:#ffbf00; color:#000; }
    .coral { background:#ff7f50; }

    .purple { background:#7d3cff; }
    .violet { background:#8e44ad; }
    .indigo { background:#3f51b5; }
    .magenta { background:#ff00aa; }
    .pink { background:#ff78c4; }

    .gold { background:#d4af37; }
    .rose { background:#ffb6c1; color:#000; }
    .slate { background:#6c7a89; }
    .brown { background:#8b4513; }
    .aqua { background:#30e3ca; }

    /* FOOTER */
    .footer {
        width: 100%;
        text-align: center;
        color: var(--theme-footer-text);
        margin-top: 40px;
        padding-bottom: 20px;
        font-size: 12px;
        letter-spacing: 0.2px;
    }

    /* STATUS POPUP */
    .popup-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.45);
        backdrop-filter: blur(4px);
        display: none;
        justify-content: center;
        align-items: center;
        z-index: 2000;
    }

    .popup-box {
        width: 680px;
        max-width: 95%;
        background: #ffffff;
        border-radius: 12px;
        box-shadow: 0 0 25px rgba(0,0,0,0.25);
        overflow: hidden;
        box-sizing: border-box;
    }

    .popup-header {
        padding: 16px 22px;
        background: var(--theme-popup-header-bg);
        color: var(--theme-popup-header-text);
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 15px;
        font-weight: 600;
    }

    .popup-close {
        background: none;
        border: none;
        color: white;
        font-size: 18px;
        cursor: pointer;
    }

    .current-status-summary {
        background: #f2f2f2;
        border-radius: 8px;
        padding: 14px 16px;
        margin-bottom: 16px;
    }

    .current-status-summary-header {
        font-size: 12px;
        font-weight: 700;
        color: #555;
        text-transform: uppercase;
        letter-spacing: 0.4px;
        margin-bottom: 20px;
    }

    .popup-content {
        padding: 20px 24px 10px 24px;
        font-size: 13px;
        color: #222;
        box-sizing: border-box;
    }

    .popup-row {
        display: flex;
        gap: 40px;
        margin-bottom: 14px;
    }

    .popup-col {
        flex: 1;
    }

    .popup-label {
        font-weight: 600;
        margin-bottom: 4px;
        display: inline-block;
    }

    .popup-value {
        font-weight: 500;
    }

    .popup-field {
        margin-bottom: 14px;
    }

    .popup-field label {
        display: block;
        font-size: 13px;
        font-weight: 600;
        margin-bottom: 4px;
    }

    .popup-field select,
    .popup-field input,
    .popup-field textarea {
        width: 100%;
        box-sizing: border-box;
        padding: 9px 11px;
        border-radius: 6px;
        border: 1px solid #ccc;
        font-size: 13px;
        font-family: inherit;
    }

    .popup-field textarea {
        min-height: 70px;
        resize: vertical;
    }

    .quick-buttons {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        margin: 6px 0 10px 0;
    }

    .quick-btn {
        padding: 6px 10px;
        border-radius: 6px;
        border: none;
        font-size: 12px;
        cursor: pointer;
        background: #e3e7f0;
        color: #1c2733;
    }

    .quick-btn:hover {
        background: #d1d7e5;
    }

    .checkbox-row {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 12px;
        margin: 4px 0 10px 0;
    }

    .popup-actions {
        padding: 12px 22px 14px 22px;
        background: #f5f5f5;
        text-align: right;
        box-sizing: border-box;
    }

    .popup-btn {
        padding: 8px 16px;
        border-radius: 6px;
        border: none;
        cursor: pointer;
        font-size: 13px;
        margin-left: 8px;
    }

    .popup-btn.cancel { background:#ddd; }
    .popup-btn.save { background: var(--theme-popup-header-bg); color: var(--theme-popup-header-text); }
</style>
</head>

<body>
<%- include('partials/theme-decorations') %>

<%
    const currentUserName = (user && user.name) ? user.name : "User";
    const isAdmin = user && user.role === "admin";
    const currentUserInitials = currentUserName.split(' ').map(w => w[0]).join('').substring(0,2).toUpperCase();
%>

<!-- HEADER -->
<div class="header">
    <div class="header-left">
        <div class="logo">
            <%
                const dashLogoSrc = tk.logo_image
                    ? tk.logo_image
                    : ((branding && branding.logo_path) ? branding.logo_path : '/img/attendr.png');
            %>
            <img src="<%= dashLogoSrc %>" alt="Logo">
        </div>
        <div class="org-name"><%= (settings && settings.org_name) ? settings.org_name : "Attendr" %></div>
    </div>

    <div class="header-right">
        <% if (isAdmin) { %>
            <a href="/admin/settings/users" class="admin-btn">Admin</a>
        <% } %>

        <div class="search-box">
            <input id="searchInput" type="text" placeholder="Search">
        </div>

        <div class="user-meta">
            <%
                const headerPhoto = photoMap && photoMap[user.id];
                const headerInitials = currentUserInitials;
            %>

            <!-- ✅ NEW: Avatar in header linking to own profile -->
            <a href="/profile" title="View my profile">
                <% if (headerPhoto) { %>
                    <img class="header-avatar"
                         src="<%= headerPhoto %>"
                         alt="<%= currentUserName %>">
                <% } else { %>
                    <div class="header-avatar-initials"><%= headerInitials %></div>
                <% } %>
            </a>

            Logged in as
            <a href="/profile"><strong><%= currentUserName %></strong></a> |
            <a href="/logout">Logout</a>
        </div>
    </div>
</div>

<!-- TABS -->
<div class="tabs" id="deptTabs">
    <div class="tab active" data-dept="ALL">All</div>

    <% departments.forEach(d => { %>
        <div
            class="tab"
            data-dept="<%= d.name %>"
            data-dept-id="<%= d.id %>"
        >
            <%= d.name %>
        </div>
    <% }) %>
</div>


<!-- TABLE -->
<div class="table-wrapper<%= (themeTokens.decorations && themeTokens.decorations.table_border) ? ' candy-frame' : '' %>">
    <% if (themeTokens.decorations && themeTokens.decorations.panel_front_bl) { %><img class="panel-deco panel-deco--bl" src="<%= themeTokens.decorations.panel_front_bl %>" alt="" aria-hidden="true"><% } %>
    <table id="staffTable">
        <thead>
            <tr>
                <th>Name</th>
                <th>Status</th>
                <th>Location</th>
                <th>Returning</th>
                <th>Comments</th>
                <th>Last Updated</th>
            </tr>
        </thead>

        <tbody>
            <% if (users && users.length) { %>
                <% users.forEach(u => { %>
                    <tr class="user-row"
                        data-user-id="<%= u.id %>"
                        data-user-name="<%= u.name || '' %>"
                        data-status-id="<%= u.status_id || '' %>"
                        data-location-id="<%= u.location_id || '' %>"
                        data-location-name="<%= u.location_name || '' %>"
                        data-returning="<%= u.returning_at || '' %>"
                        data-comment="<%= u.comment || '' %>"
                        data-departments="<%= u.departments || '' %>"
                        data-department-ids="<%= u.department_ids || '' %>">

                        <!-- ✅ UPDATED: Name cell with avatar -->
                        <td>
                            <div class="user-name-cell">
                                <% const userPhoto = photoMap && photoMap[u.id]; %>
                                <% const userInitials = u.name ? u.name.split(' ').map(w => w[0]).join('').substring(0,2).toUpperCase() : '?'; %>

                                <% if (userPhoto) { %>
                                    <img class="user-avatar"
                                         src="<%= userPhoto %>"
                                         alt="<%= u.name %>">
                                <% } else { %>
                                    <div class="user-avatar-initials"><%= userInitials %></div>
                                <% } %>

                               <span><%= u.name || '' %></span>
                        
                            </div>
                        </td>

                        <td>
                            <%
                                const stName  = u.status_name || "Unspecified";
                                const stClass = stName === "Unspecified" ? "black" : (u.status_color || "black");
                            %>
                            <span class="badge <%= stClass %>"><%= stName %></span>
                        </td>

                        <td>
                            <%= u.location_name || "Unspecified" %>
                        </td>

                        <td class="returning-cell"
                            data-raw-return="<%= u.returning_at || '' %>">
                            <%= u.returning_at || "Unspecified" %>
                        </td>

                        <td><%= u.comment || "" %></td>

                        <td class="last-updated-cell">
                            <% if (u.last_updated) { %>
                                <div class="last-updated-date" data-raw="<%= u.last_updated %>">
                                    <%= u.last_updated %>
                                </div>
                                <div class="last-updated-by">
                                    by <%= u.updated_by || "System" %>
                                </div>
                            <% } else { %>
                                —
                            <% } %>
                        </td>

                    </tr>
                <% }) %>
            <% } else { %>
                <tr><td colspan="6">No staff found.</td></tr>
            <% } %>
        </tbody>
    </table>
</div>

<!-- FOOTER -->
<div class="footer">
    © <%= new Date().getFullYear() %> Attendr. Australian Owned And Operated. All Rights Reserved.
    <% if (tk.footer_tagline) { %><br><%= tk.footer_tagline %><% } %>
</div>

<!-- UPDATE STATUS POPUP -->
<div id="statusPopup" class="popup-overlay">
    <div class="popup-box">
        <div class="popup-header">
            <div>Update Status</div>
            <button class="popup-close" type="button" onclick="closeStatusPopup()">✖</button>
        </div>

        <form id="statusForm" method="POST" action="/status/update">
            <input type="hidden" name="user_id" id="popupUserId">
            <input type="hidden" name="active_tab" id="activeTabInput">

            <div class="popup-content">
                <!-- CURRENT STATUS SUMMARY (read-only) -->
                <div class="current-status-summary">
                    <div class="current-status-summary-header">Current status</div>

                    <div class="popup-row">
                        <div class="popup-col">
                            <span class="popup-label">Name:</span>
                            <span class="popup-value" id="popupName">—</span>
                        </div>
                        <div class="popup-col">
                            <span class="popup-label">Current status:</span>
                            <span class="popup-value" id="popupStatusSummary">Unspecified</span>
                        </div>
                    </div>

                    <div class="popup-row">
                        <div class="popup-col">
                            <span class="popup-label">Returning:</span>
                            <span class="popup-value" id="popupReturningSummary">Unknown</span>
                        </div>
                        <div class="popup-col">
                            <span class="popup-label">Current comment:</span>
                            <span class="popup-value" id="popupCommentSummary">—</span>
                        </div>
                    </div>
                </div>

                <hr style="border:none;border-top:1px solid #e0e0e0;margin:10px 0 16px 0;">

                <!-- Editable fields -->
                <div class="popup-row">
                    <div class="popup-col">
                        <div class="popup-field">
                            <label for="statusSelect">Status</label>
                            <select id="statusSelect" name="status_id" required>
                                <option value="">Select status...</option>
                                <% if (statuses && statuses.length) { %>
                                    <% statuses.forEach(s => { %>
                                        <option value="<%= s.id %>" data-color="<%= s.color %>">
                                            <%= s.name %>
                                        </option>
                                    <% }) %>
                                <% } %>
                            </select>
                        </div>

                        <div class="popup-field">
                            <label>One-Click Return Time</label>
                            <div class="quick-buttons">
                                <button type="button" class="quick-btn" data-minutes="60">1 Hour</button>
                                <button type="button" class="quick-btn" data-minutes="180">3 Hours</button>
                                <button type="button" class="quick-btn" data-minutes="240">4 Hours</button>
                                <button type="button" class="quick-btn" data-minutes="1440">1 Day</button>
                            </div>
                        </div>
                    </div>

                    <div class="popup-col">
                        <div class="popup-field">
                            <label for="returningAt">Returning</label>
                            <input type="datetime-local" id="returningAt" name="returning_at">
                        </div>

                        <div class="checkbox-row">
                            <input type="checkbox" id="unknownReturn" name="unknown_return">
                            <label for="unknownReturn">Unknown Date/Time</label>
                        </div>

                        <div class="popup-field">
                            <label for="locationSelect">Location
                                <% if (detectedLocationId) { %>
                                    <span id="cidrBadge" style="
                                        font-size:11px; font-weight:500;
                                        background:#e8f5e9; color:#2e7d32;
                                        border-radius:4px; padding:2px 7px;
                                        margin-left:8px; vertical-align:middle;
                                    ">📍 Auto-detected</span>
                                <% } %>
                            </label>
                            <select id="locationSelect" name="location_id">
                                <option value="">Unspecified</option>
                                <% if (locations && locations.length) { %>
                                    <% locations.forEach(loc => { %>
                                        <option value="<%= loc.id %>"
                                            <%= detectedLocationId && loc.id === detectedLocationId ? 'selected' : '' %>
                                        ><%= loc.name %></option>
                                    <% }) %>
                                <% } %>
                            </select>
                            <% if (!detectedLocationId && locations && locations.length) { %>
                                <div style="font-size:11px;color:#888;margin-top:4px;">
                                    No location auto-detected for your IP — please select manually.
                                </div>
                            <% } %>
                        </div>
                    </div>
                </div>

                <div class="popup-field">
                    <label for="comment">Comment</label>
                    <textarea id="comment" name="comment"></textarea>
                </div>
            </div>

            <div class="popup-actions">
                <button type="button" class="popup-btn cancel" onclick="closeStatusPopup()">Cancel</button>
                <button type="submit" class="popup-btn save">OK</button>
            </div>
        </form>
    </div>
</div>


<script>
document.addEventListener("DOMContentLoaded", () => {

    function formatAusDate(raw) {
        if (!raw) return "—";
        let d;
        if (raw.endsWith("Z")) {
            d = new Date(raw);
        } else {
            d = new Date(raw.replace(" ", "T"));
        }
        if (isNaN(d.getTime())) return raw;
        return d.toLocaleString("en-AU", {
            day: "2-digit",
            month: "2-digit",
            year: "numeric",
            hour: "2-digit",
            minute: "2-digit",
            hour12: true
        });
    }

    // FORMAT RETURNING TIMES
    document.querySelectorAll(".returning-cell").forEach(cell => {
        const raw = cell.getAttribute("data-raw-return");
        if (!raw) {
            cell.innerText = "Unspecified";
            return;
        }
        cell.innerText = formatAusDate(raw);
    });

    // FORMAT LAST UPDATED TIMES
    document.querySelectorAll(".last-updated-date").forEach(el => {
        const raw = el.getAttribute("data-raw");
        if (!raw) return;
        el.innerText = formatAusDate(raw);
    });

});
</script>

<script>
var currentDeptFilter = "ALL";
var currentDeptNameFilter = "ALL";
</script>

<script>
document.addEventListener("DOMContentLoaded", () => {

    // DEPARTMENT TAB FILTER
    document.querySelectorAll("#deptTabs .tab").forEach(tab => {
        tab.addEventListener("click", () => {
            document.querySelectorAll("#deptTabs .tab")
                .forEach(t => t.classList.remove("active"));
            tab.classList.add("active");
            currentDeptFilter = tab.getAttribute("data-dept-id") || "ALL";
            currentDeptNameFilter = tab.getAttribute("data-dept") || "ALL";
            const url = new URL(window.location);
            url.searchParams.set("dept", currentDeptFilter);
            window.history.replaceState({}, "", url);
            applyFilters();
        });
    });

    // DEFAULT DEPARTMENT (FROM SERVER)
    <% if (defaultDeptId) { %>
        setTimeout(() => {
            const defaultTab = document.querySelector(
                '#deptTabs .tab[data-dept-id="<%= defaultDeptId %>"]'
            );
            if (defaultTab) defaultTab.click();
        }, 0);
    <% } %>

    // URL OVERRIDE (?dept=)
    const params = new URLSearchParams(window.location.search);
    const deptFromUrl = params.get("dept");
    if (deptFromUrl) {
        document.querySelectorAll("#deptTabs .tab").forEach(tab => {
            const tabDeptId = tab.getAttribute("data-dept-id");
            const tabDeptName = tab.getAttribute("data-dept") || "";
            const tabDeptSlug = tabDeptName.replace(/\s+/g, "-");

            if (tabDeptId === deptFromUrl || tabDeptName === deptFromUrl || tabDeptSlug === deptFromUrl) {
                tab.click();
            }
        });
    }

});

// SEARCH FILTER
document.getElementById("searchInput").addEventListener("keyup", function () {
    applyFilters();
});

function applyFilters() {
    const filterText = document.getElementById("searchInput").value.toLowerCase();
    const deptFilter = String(currentDeptFilter).toLowerCase();
    const deptNameFilter = String(currentDeptNameFilter).toLowerCase();

    document.querySelectorAll("tr.user-row").forEach(row => {
        const rowText = row.innerText.toLowerCase();
        const matchesSearch = rowText.includes(filterText);

        let matchesDept = true;
        if (deptFilter !== "all") {
            const deptIdList = (row.getAttribute("data-department-ids") || "")
                .toLowerCase()
                .split(",")
                .map(d => d.trim());

            const deptNameList = (row.getAttribute("data-departments") || "")
                .toLowerCase()
                .split(",")
                .map(d => d.trim());

            matchesDept = deptIdList.includes(deptFilter) || deptNameList.includes(deptNameFilter);
        }

        row.style.display = (matchesDept && matchesSearch) ? "" : "none";
    });
}

// POPUP
const popup = document.getElementById("statusPopup");
const statusSelect = document.getElementById("statusSelect");
const returningAtInput = document.getElementById("returningAt");
const unknownReturnCheckbox = document.getElementById("unknownReturn");
const commentInput = document.getElementById("comment");
const locationSelect = document.getElementById("locationSelect");
const activeTabInput = document.getElementById("activeTabInput");

function utcToLocalDatetimeInput(utc) {
    if (!utc) return "";
    const d = new Date(utc);
    if (isNaN(d)) return "";
    const pad = n => String(n).padStart(2, "0");
    return `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())}T${pad(d.getHours())}:${pad(d.getMinutes())}`;
}

function openStatusPopup(row) {
    activeTabInput.value = currentDeptFilter;

    const userId     = row.getAttribute("data-user-id");
    const name       = row.getAttribute("data-user-name") || "";
    const statusId   = row.getAttribute("data-status-id") || "";
    const returning  = row.getAttribute("data-returning") || "";
    const comment    = row.getAttribute("data-comment") || "";
    const locationId = row.getAttribute("data-location-id") || "";

    document.getElementById("popupUserId").value = userId;
    document.getElementById("popupName").innerText = name;

    statusSelect.value = statusId || "";
    commentInput.value = "";

    if (locationSelect) {
        const detectedId = "<%= detectedLocationId || '' %>";
        locationSelect.value = locationId || detectedId || "";
    }

    let dtValue = "";
    if (returning && returning.includes("T")) {
        dtValue = utcToLocalDatetimeInput(returning);
    }

    returningAtInput.value = dtValue;
    unknownReturnCheckbox.checked = !dtValue;
    returningAtInput.disabled = unknownReturnCheckbox.checked;

    updateSummaryFromForm();
    popup.style.display = "flex";
}

function closeStatusPopup() {
    popup.style.display = "none";
}

popup.addEventListener("click", e => {
    if (e.target === popup) closeStatusPopup();
});

// ✅ UPDATED: Row click — don't open popup when clicking name link
document.querySelectorAll("tr.user-row").forEach(row => {
    row.addEventListener("click", (e) => {
        if (e.target.closest(".user-name-link")) return;
        openStatusPopup(row);
    });
});

// ONE-CLICK RETURN BUTTONS
function toLocalDatetimeInputValue(date) {
    const pad = n => String(n).padStart(2, "0");
    return `${date.getFullYear()}-${pad(date.getMonth()+1)}-${pad(date.getDate())}T${pad(date.getHours())}:${pad(date.getMinutes())}`;
}

document.querySelectorAll(".quick-btn").forEach(btn => {
    btn.addEventListener("click", () => {
        const minutes = parseInt(btn.dataset.minutes, 10) || 0;
        const now = new Date();
        now.setMinutes(now.getMinutes() + minutes);
        returningAtInput.value = toLocalDatetimeInputValue(now);
        unknownReturnCheckbox.checked = false;
        returningAtInput.disabled = false;
        updateSummaryFromForm();
    });
});

unknownReturnCheckbox.addEventListener("change", () => {
    returningAtInput.disabled = unknownReturnCheckbox.checked;
    if (unknownReturnCheckbox.checked) returningAtInput.value = "";
    updateSummaryFromForm();
});

returningAtInput.addEventListener("change", updateSummaryFromForm);
statusSelect.addEventListener("change", updateSummaryFromForm);
commentInput.addEventListener("input", updateSummaryFromForm);

function updateSummaryFromForm() {
    const statusText =
        statusSelect.options[statusSelect.selectedIndex]?.text || "Unspecified";
    document.getElementById("popupStatusSummary").innerText = statusText;

    let returningText = "Unspecified";
    if (unknownReturnCheckbox.checked) returningText = "Unknown";
    else if (returningAtInput.value) returningText = returningAtInput.value.replace("T", " ");

    document.getElementById("popupReturningSummary").innerText = returningText;
    document.getElementById("popupCommentSummary").innerText = commentInput.value || "";
}
// ================================================
// LIVE DASHBOARD POLLING
// Silently fetches current user statuses every 30
// seconds and updates only the rows that changed.
// Does NOT refresh the page — popup stays open.
// ================================================
 
const POLL_INTERVAL_MS = 30000; // 30 seconds
 
// Colour classes that map to status badge CSS
// Must match the badge classes in your CSS
function getBadgeClass(color) {
    const validColors = [
        "black","darkgrey","grey","lightgrey","white",
        "navy","blue","sky","cyan","teal",
        "darkgreen","green","lightgreen","mint","lime",
        "maroon","red","orange","amber","coral",
        "purple","violet","indigo","magenta","pink",
        "gold","rose","slate","brown","aqua"
    ];
    return validColors.includes(color) ? color : "black";
}
 
function formatAusDatePoll(raw) {
    if (!raw) return "—";
    let d;
    if (raw.endsWith("Z")) {
        d = new Date(raw);
    } else {
        d = new Date(raw.replace(" ", "T"));
    }
    if (isNaN(d.getTime())) return raw;
    return d.toLocaleString("en-AU", {
        day: "2-digit", month: "2-digit", year: "numeric",
        hour: "2-digit", minute: "2-digit", hour12: true
    });
}
 
function formatReturningPoll(raw) {
    if (!raw) return "Unspecified";
    return formatAusDatePoll(raw);
}
 
async function pollDashboard() {
    try {
        const res  = await fetch("/api/dashboard-data");
        const data = await res.json();
 
        if (!data.ok || !data.users) return;
 
        for (const u of data.users) {
            const row = document.querySelector(`tr[data-user-id="${u.id}"]`);
            if (!row) continue;
 
            // --- STATUS BADGE ---
            const badgeEl = row.querySelector(".badge");
            if (badgeEl) {
                const newName  = u.status_name  || "Unspecified";
                const newClass = getBadgeClass(u.status_color || "black");
 
                // Only update if changed to avoid unnecessary DOM writes
                if (badgeEl.textContent.trim() !== newName) {
                    badgeEl.textContent = newName;
                    // Remove all colour classes and apply new one
                    badgeEl.className = `badge ${newClass}`;
                }
            }
 
            // --- LOCATION ---
            const cells = row.querySelectorAll("td");
            // td[0]=name, td[1]=status, td[2]=location, td[3]=returning, td[4]=comments, td[5]=last updated
            if (cells[2]) {
                const newLoc = u.location_name || "Unspecified";
                if (cells[2].textContent.trim() !== newLoc) {
                    cells[2].textContent = newLoc;
                }
            }
 
            // --- RETURNING ---
            if (cells[3]) {
                const returningCell = row.querySelector(".returning-cell");
                if (returningCell) {
                    const newReturning = formatReturningPoll(u.returning_at);
                    if (returningCell.textContent.trim() !== newReturning) {
                        returningCell.textContent = newReturning;
                        returningCell.setAttribute("data-raw-return", u.returning_at || "");
                    }
                }
            }
 
            // --- COMMENTS ---
            if (cells[4]) {
                const newComment = u.comment || "";
                if (cells[4].textContent.trim() !== newComment) {
                    cells[4].textContent = newComment;
                }
            }
 
            // --- LAST UPDATED ---
            const lastUpdatedCell = row.querySelector(".last-updated-cell");
            if (lastUpdatedCell) {
                const dateEl = lastUpdatedCell.querySelector(".last-updated-date");
                const byEl   = lastUpdatedCell.querySelector(".last-updated-by");
 
                if (u.last_updated) {
                    const formatted = formatAusDatePoll(u.last_updated);
 
                    if (dateEl) {
                        if (dateEl.getAttribute("data-raw") !== u.last_updated) {
                            dateEl.setAttribute("data-raw", u.last_updated);
                            dateEl.textContent = formatted;
                        }
                    } else {
                        // Cell was showing "—", rebuild it
                        lastUpdatedCell.innerHTML = `
                            <div class="last-updated-date" data-raw="${u.last_updated}">${formatted}</div>
                            <div class="last-updated-by">by ${u.updated_by || "System"}</div>
                        `;
                    }
 
                    if (byEl) {
                        const newBy = `by ${u.updated_by || "System"}`;
                        if (byEl.textContent.trim() !== newBy) {
                            byEl.textContent = newBy;
                        }
                    }
                } else {
                    if (lastUpdatedCell.textContent.trim() !== "—") {
                        lastUpdatedCell.textContent = "—";
                    }
                }
            }
 
            // --- UPDATE DATA ATTRIBUTES so popup opens with fresh data ---
            row.setAttribute("data-status-id",    u.status_id    || "");
            row.setAttribute("data-location-id",  u.location_id  || "");
            row.setAttribute("data-location-name", u.location_name || "");
            row.setAttribute("data-returning",     u.returning_at  || "");
            row.setAttribute("data-comment",       u.comment       || "");
        }
 
    } catch (err) {
        // Silent fail — polling errors should never disrupt the user
        console.warn("Dashboard poll failed:", err.message);
    }
}

async function refreshDetectedLocation() {
    try {
        await fetch("/api/location/refresh", {
            method: "POST",
            headers: { "Accept": "application/json" }
        });
    } catch (err) {
        console.warn("Location refresh failed:", err.message);
    }
}
 
// Start polling after initial page load settles
setTimeout(() => {
    refreshDetectedLocation().finally(pollDashboard);
    setInterval(() => {
        refreshDetectedLocation().finally(pollDashboard);
    }, POLL_INTERVAL_MS);
}, 2000);

document.addEventListener("visibilitychange", () => {
    if (!document.hidden) {
        refreshDetectedLocation().finally(pollDashboard);
    }
});
</script>

<% if (query && (query.error === "action_unavailable" || query.error === "license_expired_admin")) { %>
<div class="popup-overlay" style="display:flex;" id="licenseNotice">
    <div class="popup-box">
        <div class="popup-header">
            <div>
                <%= query.error === "license_expired_admin" ? "Licence Expired" : "Action Unavailable" %>
            </div>
        </div>
        <div class="popup-content">
            <% if (query.error === "license_expired_admin") { %>
                <p>Access to this system is currently restricted.</p>
                <p>Please contact your system administrator.</p>
            <% } else { %>
                <p>This action is currently unavailable.</p>
                <p>Please contact your system administrator.</p>
            <% } %>
        </div>
        <div class="popup-actions">
            <button class="popup-btn save" onclick="acknowledgeLicenseNotice()">OK</button>
        </div>
    </div>
</div>

<script>
function acknowledgeLicenseNotice() {
    window.location.href = "/dashboard";
}
</script>
<% } %>

</body>
</html>
